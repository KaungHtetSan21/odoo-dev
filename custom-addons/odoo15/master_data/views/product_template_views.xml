<?xml version="1.0" encoding="utf-8"?>
<odoo>


    <record id="view_product_template_form" model="ir.ui.view">
        <field name="name">product.template.form</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='detailed_type']" position="after">
                <field name="stationery_brand"
                       placeholder="e.g. Parker, Canon, 3M" string="Brand"/>
            </xpath>
        </field>
    </record>




    <record id="product_category_stationery" model="product.category">
        <field name="name">Stationery</field>
        <field name="parent_id" ref="product.product_category_all"/>
    </record>


    <record id="action_stationery_product_template" model="ir.actions.act_window">
        <field name="name">Stationery Products</field>
        <field name="res_model">product.template</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="context">{'default_is_stationery_product': True}</field>
    </record>



<!-- 
    <menuitem id="menu_stationary_product_templates"
