<odoo>
    <data>

        <!-- Tree view for Issue Pickings -->
        <record id="view_stock_picking_issue_tree" model="ir.ui.view">
            <field name="name">stock.picking.issue.tree</field>
            <field name="model">stock.picking</field>
            <field name="arch" type="xml">
                <tree string="Issue Pickings" editable="bottom">
                    <field name="company_id" invisible="1"/>
                    <field name="name"/>
                    <field name="scheduled_date"/>
                    <field name="picking_type_id"/>
                    <field name="location_id"/>
                    <field name="location_dest_id"/>
                    <field name="state"/>
                    <field name="received_by"/>
                    <field name="business_unit_ids"/>
                </tree>
            </field>
        </record>

        
        

        <record id="action_stock_picking_issue_custom" model="ir.actions.act_window">
            <field name="name">Issue Pickings</field>
            <field name="res_model">stock.picking</field>
            <field name="view_mode">tree,form</field>
            <field name="view_id" ref="stock.vpicktree"/>
            <field name="domain">[('location_dest_id.complete_name','=','Virtual Locations/Issue')]</field>
            <field name="context">{}</field>
        </record>

        

        

        <record id="view_stock_picking_form_inherit_issue" model="ir.ui.view">
            <field name="name">stock.picking.form.issue.custom</field>
            <field name="model">stock.picking</field>
            <field name="inherit_id" ref="stock.view_picking_form"/>
            <field name="arch" type="xml">

                

                <xpath expr="//field[@name='location_dest_id']" position="after">
                    <field name="received_by"/>
                    <field name="business_unit_ids" widget="many2many_tags"/>
                    <!-- <field name="allowed_location_ids" widget="many2many_tags"/> -->
                </xpath>
                <!-- Add hidden helper field -->
                <xpath expr="//form" position="inside">
                    <field name="allowed_warehouse_ids" invisible="1"/>
                </xpath>

                <!-- Domain on picking_type -->
                <xpath expr="//field[@name='picking_type_id']" position="attributes">
                    <attribute name="domain">
                        [('warehouse_id', 'in', allowed_warehouse_ids)]
                    </attribute>
                </xpath>

            </field>
        </record>



         <!-- Inherit the detailed operations tree view -->
        <record id="view_stock_move_line_detailed_operation_tree_inherit_issue" model="ir.ui.view">
            <field name="name">stock.move.line.detailed.operation.tree.issue.custom</field>
            <field name="model">stock.move.line</field>
            <field name="inherit_id" ref="stock.view_stock_move_line_detailed_operation_tree"/>
            <field name="arch" type="xml">

                <!-- Ensure tree is editable -->
                <xpath expr="//tree" position="attributes">
                    <attribute name="editable">bottom</attribute>
                </xpath>

                <!-- Add On-Hand column after product_id -->
                <xpath expr="//field[@name='product_id']" position="after">
                    <field name="source_location_onhand" readonly="1"/>
                </xpath>

                <!-- Add Received By column after qty_done -->
                <xpath expr="//field[@name='qty_done']" position="after">
                    <field name="received_by"/>
                </xpath>

                <!-- Hide unnecessary columns -->
                <xpath expr="//field[@name='lot_id']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
                <xpath expr="//field[@name='location_id']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
                <xpath expr="//field[@name='location_dest_id']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>

            </field>
        </record>

        

        <!-- <menuitem id="menu_internal_issue_request"
              name="Issue Requests"
              parent="menu_stationary_internal"
              action="action_stock_picking_issue_custom"
              sequence="10"/> -->
        
    </data>
</odoo>