<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Department Form View - Add Business Unit Field -->
    <record id="view_department_form_inherit_business_unit" model="ir.ui.view">
        <field name="name">hr.department.form.inherit.business.unit</field>
        <field name="model">hr.department</field>
        <field name="inherit_id" ref="hr.view_department_form"/>
        <field name="arch" type="xml">

            <!-- Add Business Unit field after Manager -->
            <xpath expr="//field[@name='manager_id']" position="after">
                <field name="business_unit_id"
                       string="Business Unit"
                       options="{'no_create': True}"
                       placeholder="Select Business Unit"/>
            </xpath>

        </field>
    </record>

</odoo>