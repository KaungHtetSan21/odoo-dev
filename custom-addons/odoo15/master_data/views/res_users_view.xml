<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Employee Form View - Inherit -->
    <record id="view_employee_form_inherit_business_unit" model="ir.ui.view">
        <field name="name">hr.employee.form.inherit.business.unit</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">

            <!-- Insert after Department field -->
            <xpath expr="//field[@name='department_id']" position="after">
                <field name="business_unit_ids"
                       string="Business Units"
                       widget="many2many_tags"
                       placeholder="Select Business Units"/>
            </xpath>

        </field>
    </record>

    <!-- Users Form View - Inherit -->
    <record id="view_users_form_business_unit" model="ir.ui.view">
        <field name="name">res.users.form.business.unit</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='company_ids']" position="after">
                <group string="Business Units" name="business_units_group">
                    <field name="business_unit_ids"
                           string="Business Units"
                           widget="many2many_tags"
                           placeholder="Select Business Units"/>
                </group>
            </xpath>
        </field>
    </record>

</odoo>