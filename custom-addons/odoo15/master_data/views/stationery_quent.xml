<odoo>
    <record id="view_stock_quant_office_tree" model="ir.ui.view">
        <field name="name">stock.quant.office.tree</field>
        <field name="model">stock.quant</field>
        <field name="arch" type="xml">
            <tree>
                <field name="product_id"/>
                <field name="location_id"/>
                <field name="lot_id" string="Lot/Serial"/>
                <field name="quantity"  class="fw-bold"/>
                <field name="office_issued_qty"  class="fw-bold"/>
                <field name="office_remaining_qty"  class="fw-bold"/>
                <field name="product_uom_id" string="UoM"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </tree>
        </field>
    </record>




    <record id="action_office_stock_report" model="ir.actions.act_window">
        <field name="name">Office Stock</field>
        <field name="res_model">stock.quant</field>
        <field name="view_mode">tree</field>
        <field name="view_id" ref="view_stock_quant_office_tree"/>
        <field name="domain">[('location_id.usage','=','internal')]</field>
    </record>

    <!-- <menuitem id="menu_office_stock"
            name="Office Stock"
            parent="menu_stationary_internal"
            action="action_office_stock_report"/> -->

</odoo>


