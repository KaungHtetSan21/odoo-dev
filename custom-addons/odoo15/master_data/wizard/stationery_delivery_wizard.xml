<odoo>


    <record id="view_stationery_delivery_wizard_form" model="ir.ui.view">

        <field name="name">stationery.delivery.wizard.form</field>
        <field name="model">stationery.delivery.wizard</field>
        <field name="arch" type="xml">
            <form string="Confirm Delivery">


                        <div class="o_form_label">
                            Please check the items before making stock movements.
                        </div>
                        <field name="line_ids">
                            <tree create="0" delete="0" decoration-success="is_checked" editable="false">
                                <field name="product_id" readonly="1"/>
                                <field name="quantity" readonly="1"/>
                                <field name="is_checked" widget="boolean_toggle"/>
                            </tree>
                        </field>



                    <footer>
                        <button name="action_confirm_delivery"
                                string="Confirm Delivery"
                                type="object"
                                class="btn-primary"/>
                        <button string="Cancel"
                                special="cancel"
                                class="btn-secondary"/>
                    </footer>


            </form>
        </field>
    </record>


</odoo>