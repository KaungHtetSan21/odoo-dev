<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_stationery_reject_wizard" model="ir.ui.view">
        <field name="name">stationery.reject.wizard.form</field>
        <field name="model">stationery.transfer.reject.wizard</field>
        <field name="arch" type="xml">
            <form string="Reject Request">
                <group>
                    <field name="reject_reason" nolabel="1" placeholder="Enter reject reason..."/>
                </group>
                <footer>
                    <button name="action_confirm_reject"
                            string="Reject" 
                            type="object" 
                            class="btn-danger"/>
                    <button string="Cancel"
                            class="btn-secondary" 
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_stationery_reject_wizard" model="ir.actions.act_window">
        <field name="name">Reject Request</field>
        <field name="res_model">stationery.transfer.reject.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record> 

</odoo>