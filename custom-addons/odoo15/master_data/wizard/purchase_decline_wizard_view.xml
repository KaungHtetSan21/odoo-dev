<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- Wizard Form View -->
    <record id="view_purchase_decline_wizard_form" model="ir.ui.view">
        <field name="name">purchase.decline.wizard.form</field>
        <field name="model">purchase.decline.wizard</field>
        <field name="arch" type="xml">
            <form string="Decline Purchase Order">
                <group>
                    <field name="purchase_id" invisible="1"/>

                    <field name="decline_reason" widget="radio" required="1"/>

                    <field name="decline_reason_note"
                           attrs="{
                               'invisible': [('decline_reason','!=','other')],
                               'required': [('decline_reason','=','other')]
                           }"
                           placeholder="Please specify the reason..."/>
                </group>

                <footer>
                    <button name="action_confirm_decline"
                            string="Confirm Decline"
                            type="object"
                            class="btn-danger"/>

                    <button string="Cancel"
                            special="cancel"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>