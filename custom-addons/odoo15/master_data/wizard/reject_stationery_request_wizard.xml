<odoo>
    <record id="view_stationery_request_reject_wizard_form" model="ir.ui.view">
        <field name="name">stationery.request.reject.wizard.form</field>
        <field name="model">stationery.request.reject.wizard</field>
        <field name="arch" type="xml">
            <form string="Reject Request">
                <group>
                    <field name="request_id"/>
                    <field name="rejected_by"/>
                    <field name="rejected_date"/>
                    <field name="reject_reason" placeholder="Enter rejection reason..."/>
                </group>
                <footer>
                    <button name="action_confirm_reject" type="object"
                            string="Reject" class="btn-danger"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>